# ============================================
# SUPABASE — Variables de conexión
# ============================================

# URL del proyecto Supabase (pública, se usa en cliente y servidor)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima pública (segura para el navegador, respeta RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publico

# Service Role Key — ⚠️ NUNCA expongas esta clave al frontend.
# Úsala solo en API Routes / Server Actions para operaciones admin.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreto

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# CORS (opcional)
# ============================================
# Origen permitido para peticiones a la API.
# Usa "*" para desarrollo o la URL de tu app Flutter/Web en producción.
# ALLOWED_ORIGIN=*
